# Copy this file to .env and fill real values.
# .env is git-ignored by default.

ECBOT_EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY
ECBOT_GENERATION_API_KEY=YOUR_GENERATION_API_KEY
ECBOT_EMBEDDING_MODEL=text-embedding-v4
ECBOT_GENERATION_MODEL=qwen-plus

ECBOT_FEISHU_APP_ID=YOUR_FEISHU_APP_ID
ECBOT_FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
ECBOT_FEISHU_VERIFICATION_TOKEN=YOUR_FEISHU_VERIFICATION_TOKEN
ECBOT_FEISHU_ENCRYPT_KEY=YOUR_FEISHU_ENCRYPT_KEY
ECBOT_FEISHU_TARGET_CHAT_ID=YOUR_FEISHU_TARGET_CHAT_ID

# Optional
# ECBOT_FEISHU_RECEIVE_MODE=long_connection
# ECBOT_DOTENV_PATH=.env
# ECBOT_KB_OCR_ENABLED=true
# ECBOT_KB_OCR_LANGUAGE=chi_sim+eng
# ECBOT_KB_OCR_DPI_SCALE=2.0
# ECBOT_KB_OCR_TRIGGER_READABILITY=0.58
# ECBOT_KB_MIN_CHUNK_READABILITY=0.38
# ECBOT_KB_AUTO_INIT_ON_STARTUP=false
# ECBOT_KB_INIT_BLOCKING=false
# ECBOT_KB_INIT_FAIL_OPEN=true
# ECBOT_WEB_SEARCH_ENABLED=false
# ECBOT_WEB_SEARCH_PROVIDER=mock
# ECBOT_WEB_SEARCH_TIMEOUT=8
# ECBOT_WEB_RAG_MAX_DOCS=16
# ECBOT_L1_TRIGGER_THRESHOLD=0.58
# ECBOT_L1_TEMPLATE_ENABLED=true
# ECBOT_L2_MAX_TOP_K=8
# ECBOT_SEARCH_PROGRESS_ENABLED=true
# ECBOT_SEARCH_PROGRESS_KEYWORD_TOP_K=4
# ECBOT_SOURCE_QUOTA_MODE=unbounded
# ECBOT_MAX_CHUNKS_PER_SOURCE=0
# ECBOT_WEB_DIRECT_FUSION_THRESHOLDS={"result_count_max":8,"top3_mean_min":0.72,"score_gap_min":0.08,"noise_ratio_max":0.25}
